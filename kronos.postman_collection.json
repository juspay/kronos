              { "key": "X-Workspace-Id", "value": "{{workspace_id}}" }
            ],
            "description": "Retires the job (status → RETIRED). For CRON jobs, no more ticks are scheduled.",
            "url": {
              "raw": "{{base_url}}/v1/jobs/{{job_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["v1", "jobs", "{{job_id}}", "cancel"]
            }
          }
        }
      ]
