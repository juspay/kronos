      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kronos_execution_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kronos_execution_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kronos_execution_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
